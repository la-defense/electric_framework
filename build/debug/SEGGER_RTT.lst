 438:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   volatile char* pDst;
 439:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** 
 440:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   WrOff = pRing->WrOff;
 441:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   Rem = pRing->SizeOfBuffer - WrOff;
 442:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   if (Rem > NumBytes) {
 443:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     //
 444:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     // All data fits before wrap around
 445:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     //
 446:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     pDst = (pRing->pBuffer + WrOff) + SEGGER_RTT_UNCACHED_OFF;
 447:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** #if SEGGER_RTT_MEMCPY_USE_BYTELOOP
 448:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     WrOff += NumBytes;
 449:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     while (NumBytes--) {
 450:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       *pDst++ = *pData++;
 451:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     };
 452:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     RTT__DMB();                     // Force data write to be complete before writing the <WrOff>, 
 453:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     pRing->WrOff = WrOff;
 454:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** #else
 455:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     SEGGER_RTT_MEMCPY((void*)pDst, pData, NumBytes);
 456:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     RTT__DMB();                     // Force data write to be complete before writing the <WrOff>, 
 457:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     pRing->WrOff = WrOff + NumBytes;
 458:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** #endif
 459:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   } else {
