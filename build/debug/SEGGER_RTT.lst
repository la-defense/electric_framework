 461:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     // We reach the end of the buffer, so need to wrap around
 462:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     //
 463:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** #if SEGGER_RTT_MEMCPY_USE_BYTELOOP
 464:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     pDst = (pRing->pBuffer + WrOff) + SEGGER_RTT_UNCACHED_OFF;
 465:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     NumBytesAtOnce = Rem;
 466:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     while (NumBytesAtOnce--) {
 467:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       *pDst++ = *pData++;
 468:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     };
 469:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     pDst = pRing->pBuffer + SEGGER_RTT_UNCACHED_OFF;
 470:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     NumBytesAtOnce = NumBytes - Rem;
 471:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     while (NumBytesAtOnce--) {
 472:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       *pDst++ = *pData++;
 473:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     };
 474:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     RTT__DMB();                     // Force data write to be complete before writing the <WrOff>, 
 475:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     pRing->WrOff = NumBytes - Rem;
 476:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** #else
