 904:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** /*********************************************************************
 905:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *
 906:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *       SEGGER_RTT_WriteSkipNoLock
 907:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *
 908:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *  Function description
 909:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    Stores a specified number of characters in SEGGER RTT
 910:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    control block which is then read by the host.
 911:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    SEGGER_RTT_WriteSkipNoLock does not lock the application and
 912:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    skips all data, if the data does not fit into the buffer.
 913:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *
 914:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *  Parameters
 915:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    BufferIndex  Index of "Up"-buffer to be used (e.g. 0 for "Terminal").
 916:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    pBuffer      Pointer to character array. Does not need to point to a \0 terminated string.
 917:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    NumBytes     Number of bytes to be stored in the SEGGER RTT control block.
 918:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *                 MUST be > 0!!!
 919:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *                 This is done for performance reasons, so no initial check has do be done.
ARM GAS  C:\Users\Administrator\AppData\Local\Temp\ccUGyMKj.s 			page 45


 920:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *
 921:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *  Return value
 922:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    1: Data has been copied
 923:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    0: No space, data has not been copied
 924:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *
 925:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *  Notes
 926:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    (1) If there is not enough space in the "Up"-buffer, all data is dropped.
 927:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    (2) For performance reasons this function does not call Init()
 928:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *        and may only be called after RTT has been initialized.
 929:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *        Either by calling SEGGER_RTT_Init() or calling another RTT API function first.
 930:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** */
 931:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** #if (RTT_USE_ASM == 0)
 932:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** unsigned SEGGER_RTT_WriteSkipNoLock(unsigned BufferIndex, const void* pBuffer, unsigned NumBytes) {
 933:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   const char*           pData;
 934:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   SEGGER_RTT_BUFFER_UP* pRing;
 935:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   unsigned              Avail;
 936:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   unsigned              RdOff;
 937:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   unsigned              WrOff;
 938:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   unsigned              Rem;
 939:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   volatile char*        pDst;
 940:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   //
 941:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   // Cases:
 942:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   //   1) RdOff <= WrOff => Space until wrap-around is sufficient
 943:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   //   2) RdOff <= WrOff => Space after wrap-around needed (copy in 2 chunks)
 944:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   //   3) RdOff <  WrOff => No space in buf
 945:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   //   4) RdOff >  WrOff => Space is sufficient
 946:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   //   5) RdOff >  WrOff => No space in buf
 947:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   //
 948:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   // 1) is the most common case for large buffers and assuming that J-Link reads the data fast enou
 949:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   //
 950:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   pData = (const char *)pBuffer;
 951:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   pRing = (SEGGER_RTT_BUFFER_UP*)((char*)&_SEGGER_RTT.aUp[BufferIndex] + SEGGER_RTT_UNCACHED_OFF); 
 952:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   RdOff = pRing->RdOff;
 953:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   WrOff = pRing->WrOff;
 954:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   if (RdOff <= WrOff) {                                 // Case 1), 2) or 3)
 955:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     Avail = pRing->SizeOfBuffer - WrOff - 1u;           // Space until wrap-around (assume 1 byte n
 956:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     if (Avail >= NumBytes) {                            // Case 1)?
 957:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** CopyStraight:
 958:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       pDst = (pRing->pBuffer + WrOff) + SEGGER_RTT_UNCACHED_OFF;
 959:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       memcpy((void*)pDst, pData, NumBytes);
 960:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       RTT__DMB();                     // Force data write to be complete before writing the <WrOff>
 961:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       pRing->WrOff = WrOff + NumBytes;
 962:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       return 1;
 963:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     }
 964:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     Avail += RdOff;                                     // Space incl. wrap-around
 965:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****     if (Avail >= NumBytes) {                            // Case 2? => If not, we have case 3) (does
 966:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       Rem = pRing->SizeOfBuffer - WrOff;                // Space until end of buffer
 967:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       pDst = (pRing->pBuffer + WrOff) + SEGGER_RTT_UNCACHED_OFF;
 968:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       memcpy((void*)pDst, pData, Rem);                  // Copy 1st chunk
 969:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       NumBytes -= Rem;
 970:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       //
 971:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       // Special case: First check that assumed RdOff == 0 calculated that last element before wrap
 972:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       // But 2nd check (considering space until wrap-around and until RdOff) revealed that RdOff is
 973:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       // In this case, we may use a copy straight until buffer end anyway without needing to copy 2
 974:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       // Therefore, check if 2nd memcpy is necessary at all
 975:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****       //
