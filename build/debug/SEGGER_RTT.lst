 432:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** *    (1) If there might not be enough space in the "Up"-buffer, call _WriteBlocking
 433:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** */
 434:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c **** static void _WriteNoCheck(SEGGER_RTT_BUFFER_UP* pRing, const char* pData, unsigned NumBytes) {
 435:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   unsigned NumBytesAtOnce;
 436:Middlewares/Third_Party/SEGGER/RTT/SEGGER_RTT.c ****   unsigned WrOff;
