 985:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2c.c ****         (++) HAL_I2C_Master_Seq_Receive_IT()
 986:Drivers/STM32F4xx_HAL_Driver/Src/stm32f4xx_hal_i2c.c ****         (++) HAL_I2C_Slave_Seq_Transmit_IT()
