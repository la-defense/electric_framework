 190:modules/imu/ins_task.c **** /**
 191:modules/imu/ins_task.c ****  * @brief          Transform 3dvector from BodyFrame to EarthFrame
 192:modules/imu/ins_task.c ****  * @param[1]       vector in BodyFrame
 193:modules/imu/ins_task.c ****  * @param[2]       vector in EarthFrame
 194:modules/imu/ins_task.c ****  * @param[3]       quaternion
 195:modules/imu/ins_task.c ****  */
 196:modules/imu/ins_task.c **** void BodyFrameToEarthFrame(const float *vecBF, float *vecEF, float *q)
 197:modules/imu/ins_task.c **** {
 198:modules/imu/ins_task.c ****     vecEF[0] = 2.0f * ((0.5f - q[2] * q[2] - q[3] * q[3]) * vecBF[0] +
 199:modules/imu/ins_task.c ****                        (q[1] * q[2] - q[0] * q[3]) * vecBF[1] +
 200:modules/imu/ins_task.c ****                        (q[1] * q[3] + q[0] * q[2]) * vecBF[2]);
 201:modules/imu/ins_task.c **** 
 202:modules/imu/ins_task.c ****     vecEF[1] = 2.0f * ((q[1] * q[2] + q[0] * q[3]) * vecBF[0] +
 203:modules/imu/ins_task.c ****                        (0.5f - q[1] * q[1] - q[3] * q[3]) * vecBF[1] +
 204:modules/imu/ins_task.c ****                        (q[2] * q[3] - q[0] * q[1]) * vecBF[2]);
 205:modules/imu/ins_task.c **** 
 206:modules/imu/ins_task.c ****     vecEF[2] = 2.0f * ((q[1] * q[3] - q[0] * q[2]) * vecBF[0] +
 207:modules/imu/ins_task.c ****                        (q[2] * q[3] + q[0] * q[1]) * vecBF[1] +
 208:modules/imu/ins_task.c ****                        (0.5f - q[1] * q[1] - q[2] * q[2]) * vecBF[2]);
 209:modules/imu/ins_task.c **** }
 210:modules/imu/ins_task.c **** 
 211:modules/imu/ins_task.c **** /**
 212:modules/imu/ins_task.c ****  * @brief          Transform 3dvector from EarthFrame to BodyFrame
 213:modules/imu/ins_task.c ****  * @param[1]       vector in EarthFrame
 214:modules/imu/ins_task.c ****  * @param[2]       vector in BodyFrame
 215:modules/imu/ins_task.c ****  * @param[3]       quaternion
 216:modules/imu/ins_task.c ****  */
 217:modules/imu/ins_task.c **** void EarthFrameToBodyFrame(const float *vecEF, float *vecBF, float *q)
 218:modules/imu/ins_task.c **** {
 219:modules/imu/ins_task.c ****     vecBF[0] = 2.0f * ((0.5f - q[2] * q[2] - q[3] * q[3]) * vecEF[0] +
 220:modules/imu/ins_task.c ****                        (q[1] * q[2] + q[0] * q[3]) * vecEF[1] +
 221:modules/imu/ins_task.c ****                        (q[1] * q[3] - q[0] * q[2]) * vecEF[2]);
 222:modules/imu/ins_task.c **** 
 223:modules/imu/ins_task.c ****     vecBF[1] = 2.0f * ((q[1] * q[2] - q[0] * q[3]) * vecEF[0] +
 224:modules/imu/ins_task.c ****                        (0.5f - q[1] * q[1] - q[3] * q[3]) * vecEF[1] +
 225:modules/imu/ins_task.c ****                        (q[2] * q[3] + q[0] * q[1]) * vecEF[2]);
 226:modules/imu/ins_task.c **** 
 227:modules/imu/ins_task.c ****     vecBF[2] = 2.0f * ((q[1] * q[3] + q[0] * q[2]) * vecEF[0] +
 228:modules/imu/ins_task.c ****                        (q[2] * q[3] - q[0] * q[1]) * vecEF[1] +
 229:modules/imu/ins_task.c ****                        (0.5f - q[1] * q[1] - q[2] * q[2]) * vecEF[2]);
 230:modules/imu/ins_task.c **** }
